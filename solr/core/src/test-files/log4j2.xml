<!-- Synchronous logging. Async loggers (AsyncRoot/AsyncLogger) drop buffered events when the forked
     test JVM or the Log4j context is torn down without a clean flush, which is precisely when a failing
     test emits its last (most important) request-time logs - so those traces never reach the captured
     SYSTEM_ERR output. Synchronous logging writes each event before returning and applies natural
     backpressure to flooding producers (no unbounded ring-buffer accumulation), so it also removes the
     OOM risk the async ring-buffer size cap in defaults-tests.gradle was guarding against. -->
<Configuration>
  <Appenders>
    <Console name="STDERR" target="SYSTEM_ERR" follow="true">
      <PatternLayout>
        <Pattern>
          %maxLen{%-4r %-5p (%-5t) [%X{node_name} %X{core}] %c{1.} %m%notEmpty{
          =>%ex{short}}}{10240}%n
        </Pattern>
      </PatternLayout>
    </Console>
  </Appenders>
  <Loggers>
    <Logger name="org.apache.solr.update.LoggingInfoStream" level="off"/>
    <Logger name="org.apache.zookeeper" level="WARN"/>
    <Logger name="org.apache.hadoop" level="WARN"/>
    <Logger name="org.apache.directory" level="WARN"/>
    <Logger name="org.apache.solr.hadoop" level="WARN"/>
    <Logger name="org.eclipse.jetty" level="WARN"/>

    <Root level="WARN">
      <AppenderRef ref="STDERR"/>
    </Root>
  </Loggers>
</Configuration>

<!-- Configuration for synchronous logging
     there _may_ be a very small window where log messages will not be flushed
     to the log file on abnormal shutdown. If even this risk is unacceptable, use
     the configuration below
